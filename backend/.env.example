# Copy to backend/.env and edit values

# SQLite (default if unset)
# DATABASE_URL=sqlite:///./wordquiz.db

# Postgres (recommended for multi-user production)
# If you run `docker compose -f backend/docker-compose.yml up -d`:
DATABASE_URL=postgresql+psycopg://wordquiz:wordquiz@localhost:5432/wordquiz

# JWT secret (CHANGE THIS)
JWT_SECRET_KEY=CHANGE_ME_DEV_ONLY

# React dev server
CORS_ALLOW_ORIGINS=http://localhost:5173
